---
import { ClientRouter } from "astro:transitions";
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.tsx";
import StickyMobileCTA from "@/components/StickyMobileCTA.tsx";
import { siteContact } from "@/lib/site";
import "@/styles/globals.css";

interface Props {
  title: string;
  description: string;
  canonicalURL?: string;
  ogImage?: string;
  noindex?: boolean;
  hideStickyCta?: boolean;
  schema?: object | object[];
}

const {
  title,
  description,
  canonicalURL = Astro.url.href,
  ogImage = "/og-image.jpg",
  noindex = false,
  hideStickyCta = false,
  schema,
} = Astro.props;

const fullTitle = title.includes("Priox Båtverkstad")
  ? title
  : `${title} | Priox Båtverkstad`;

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "AutomotiveBusiness",
  "@id": "https://batverkstad.se/#organization",
  name: siteContact.displayName,
  legalName: siteContact.legalName,
  alternateName: "Mickes Båtverkstad",
  identifier: siteContact.organizationNumber,
  description:
    "Mobil båtverkstad i Bohuslän. Service av utombordare, krympplastning, bottenmålning och bryggservice på plats hos kunden.",
  url: "https://batverkstad.se",
  logo: "https://batverkstad.se/android-chrome-512x512.png",
  image: "https://batverkstad.se/og-image.jpg",
  telephone: siteContact.phoneHref,
  email: siteContact.email,
  address: {
    "@type": "PostalAddress",
    streetAddress: "Box 6",
    postalCode: "457 02",
    addressLocality: siteContact.city,
    addressRegion: siteContact.region,
    addressCountry: siteContact.country,
  },
  areaServed: [
    { "@type": "AdministrativeArea", name: "Bohuslän" },
    { "@type": "AdministrativeArea", name: "Västra Götaland" },
    { "@type": "AdministrativeArea", name: "Dalsland" },
    { "@type": "AdministrativeArea", name: "Värmland" },
  ],
  geo: {
    "@type": "GeoCoordinates",
    latitude: 58.6948,
    longitude: 11.2548,
  },
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      opens: "08:00",
      closes: "17:00",
    },
  ],
  sameAs: [siteContact.facebook],
  priceRange: "$$",
};

const schemas = [
  localBusinessSchema,
  ...(schema ? (Array.isArray(schema) ? schema : [schema]) : []),
];
---

<!doctype html>
<html lang="sv">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />

    {
      noindex ? (
        <meta name="robots" content="noindex, nofollow" />
      ) : (
        <meta name="robots" content="index, follow" />
      )
    }

    <link rel="canonical" href={canonicalURL} />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#f5f1ea" />
    <meta name="apple-mobile-web-app-title" content="Priox Båtverkstad" />

    {/*
      Sajten är tills vidare låst till ljust tema (mörkt tema ses över som
      eventuell plusmeny längre fram). Vi tvingar bort ev. sparat "dark" så att
      återvändande besökare och OS i mörkt läge ändå får ljust. För att
      återaktivera mörkt tema: återställ detta script + temaväxlaren i Header.
    */}
    <script is:inline>
      (function () {
        try {
          document.documentElement.classList.remove("dark");
          var meta = document.querySelector('meta[name="theme-color"]');
          if (meta) meta.setAttribute("content", "#f5f1ea");
        } catch (e) {}
      })();
    </script>

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Priox Båtverkstad" />
    <meta property="og:locale" content="sv_SE" />
    <meta property="og:site_name" content="Priox Båtverkstad" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />
    <meta name="twitter:image:alt" content="Priox Båtverkstad" />

    {
      schemas.map((s) => (
        <script type="application/ld+json" set:html={JSON.stringify(s)} />
      ))
    }

    <ClientRouter />

    <slot name="head" />
  </head>

  <body
    class:list={[
      "min-h-screen flex flex-col bg-background text-foreground",
      !hideStickyCta && "pb-[88px] lg:pb-0",
    ]}
  >
    <a href="#main-content" class="skip-link">Hoppa till innehållet</a>

    <Header client:load transition:persist="site-header" />

    <main class="flex-1 pt-[72px]" id="main-content">
      <slot />
    </main>

    <Footer />

    {!hideStickyCta && <StickyMobileCTA client:idle transition:persist="sticky-cta" />}
  </body>
</html>
