---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="Sidan hittades inte | Mickes Båtverkstad"
  description="Sidan du letar efter finns inte. Gå tillbaka till startsidan."
  noindex={true}
>
  <section class="bg-background min-h-[60vh] flex items-center py-20 lg:py-32 relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none opacity-50">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[600px] bg-primary/10 rounded-full blur-[120px]"></div>
    </div>

    <div class="max-w-xl mx-auto px-6 text-center relative z-10">
      <p class="font-heading text-7xl lg:text-8xl font-bold text-primary/30 mb-2">404</p>
      <h1 class="font-heading text-3xl lg:text-4xl font-bold text-foreground mb-6 leading-[1.1] tracking-tight">
        Sidan finns inte
      </h1>
      <p class="text-muted-foreground text-lg leading-relaxed mb-10">
        Den här sidan kunde vi inte hitta. Den kan ha flyttat eller bara
        försvunnit.
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a
          href="/"
          class="inline-flex items-center justify-center gap-2 px-6 py-3.5 bg-primary text-primary-foreground font-bold rounded-xl hover:bg-primary/90 transition-all"
        >
          Till startsidan
        </a>
        <a
          href="/kontakt/"
          class="inline-flex items-center justify-center gap-2 px-6 py-3.5 border border-border bg-card text-foreground font-medium rounded-xl hover:border-primary/40 transition-all"
        >
          Kontakt
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
