---
import CtaSection from "@/components/sections/CtaSection.tsx";
import ShrinkWrapCalculator from "@/components/ShrinkWrapCalculator.tsx";
import BaseLayout from "@/layouts/BaseLayout.astro";

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Hem", item: "https://batverkstad.se/" },
    { "@type": "ListItem", position: 2, name: "Priser", item: "https://batverkstad.se/priser/" },
  ],
};

const services = [
  {
    title: "Årsservice utombordare",
    range: "Från 2 195 kr",
    details:
      "Årlig service på de flesta fabrikat av utombordsmotorer, direkt på plats där båten står.",
    includes: [
      "Visuell inspektion av motor och installation",
      "Byte av motorolja",
      "Byte av oljefilter",
      "Byte av växelhusolja",
      "Byte av bränslefilter",
      "Kontroll av anoder",
      "Kontroll av kylsystem och kylvattenflöde",
      "Smörjning av motor och reglage",
      "Rost- och elektronikskydd",
      "Varmkörning och funktionskontroll",
    ],
    note: "Från-priset avser arbetskostnad. Servicedelar och förbrukningsmaterial tillkommer beroende på motorfabrikat och modell. Miljöavgift och framkörningsavgift på 685 kr tillkommer. Vid behov utförs även 3-årsservice och 5-årsservice med exempelvis byte av impeller, tändstift och kamrem enligt tillverkarens intervall.",
  },
  {
    title: "Krympplastning",
    range: "Från 2 700 kr",
    details:
      "Professionell krympplastning för säker vinterförvaring. Utförs på plats och anpassas efter båtens storlek och utformning.",
    includes: [
      "Krympplast av hög kvalitet",
      "Uppvärmning och krympning på plats",
      "Förstärkning av utsatta hörn och kanter",
      "Montering av två ventilationsventiler",
      "Kontroll av täckning och ventilation",
    ],
    note: "Lägsta pris gäller båtar upp till 5,5 m, därefter 500 kr per meter upp till max 9 m. Framkörningsavgift på 685 kr tillkommer. Räkna ut ditt pris nedan.",
  },
  {
    title: "Bottenmålning",
    range: "Från 2 500 kr",
    details:
      "Professionell bottenmålning som skyddar skrovet mot påväxt och ger bästa möjliga förutsättningar inför säsongen.",
    includes: [
      "Maskering av vattenlinje och detaljer",
      "Applicering av bottenfärg",
      "Kontroll av utfört arbete",
      "Material och förbrukningsmaterial ingår",
    ],
    note: "Arbetskostnad och material från 2 500 kr beroende på båtstorlek och omfattning. Framkörningsavgift på 685 kr tillkommer.",
  },
  {
    title: "Brygganläggningar & bryggservice",
    range: "Från 1 250 kr",
    details:
      "Byggnation, ombyggnad, renovering och underhåll av bryggor, bryggdäck och landgångar. För privatpersoner, företag, samfälligheter och marinor.",
    includes: [
      "Besiktning och bedömning på plats",
      "Planering och förslag på åtgärder",
      "Byggnation, ombyggnad och reparation",
      "Slutkontroll efter utfört arbete",
    ],
    note: "Varje bryggprojekt prissätts efter besiktning på plats. Du får alltid ett tydligt förslag på åtgärder och pris innan arbetet påbörjas. Framkörningsavgift på 685 kr tillkommer.",
  },
];
---

<BaseLayout
  title="Priser | Priox Båtverkstad"
  description="Vad brukar priset vara? Från-priser för årsservice av utombordare, krympplastning, bottenmålning och bryggservice. Vi ger alltid ett kostnadsbesked innan vi börjar."
  schema={breadcrumbSchema}
>
  <section class="bg-background pt-24 pb-16 lg:pt-28 lg:pb-20 relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none opacity-50">
      <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-primary/10 rounded-full blur-[120px]"></div>
      <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-accent-sand/10 rounded-full blur-[120px]"></div>
    </div>

    <div class="max-w-(--max-w-content) mx-auto px-6 relative z-10">
      <nav aria-label="Brödsmulor" class="mb-8 text-sm text-muted-foreground">
        <a href="/" class="hover:text-foreground transition-colors">Hem</a>
        <span class="mx-2 opacity-50">/</span>
        <span class="text-foreground">Priser</span>
      </nav>

      <div class="max-w-3xl mb-6">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-6 h-[2px] bg-primary"></div>
          <span class="text-xs font-bold uppercase tracking-[0.2em] text-primary">
            Priser
          </span>
        </div>
        <h1 class="font-heading text-4xl lg:text-5xl font-bold text-foreground tracking-tight leading-[1.05] mb-6">
          Vad brukar priset vara?
        </h1>
        <p class="text-muted-foreground text-lg leading-relaxed">
          Inga ärenden ser exakt likadana ut. Här är från-priser för våra
          vanligaste tjänster, beroende på båtens storlek och skick. Alla
          priser är inklusive moms och en fast framkörningsavgift på 685 kr
          tillkommer per besök. Slutpriset bekräftas alltid innan vi börjar
          arbetet.
        </p>
      </div>
    </div>
  </section>

  <section class="bg-muted/40 py-16 lg:py-24 border-y border-border">
    <div class="max-w-(--max-w-content) mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-6 lg:gap-8">
        {
          services.map((service) => (
            <article class="bg-card border border-border rounded-2xl p-6 lg:p-8 flex flex-col">
              <h2 class="font-heading text-2xl font-bold text-foreground mb-3">
                {service.title}
              </h2>
              <p class="font-heading text-xl font-bold text-primary mb-4">
                {service.range}
              </p>
              <p class="text-muted-foreground text-sm leading-relaxed mb-5">
                {service.details}
              </p>
              <ul class="space-y-2 mt-auto pt-5 border-t border-border">
                {service.includes.map((item) => (
                  <li class="flex items-start gap-2 text-sm text-foreground">
                    <span class="w-1 h-1 rounded-full bg-primary mt-2 flex-shrink-0" />
                    <span class="leading-snug">{item}</span>
                  </li>
                ))}
              </ul>
              <p class="text-xs text-muted-foreground leading-relaxed mt-5 pt-5 border-t border-border">
                {service.note}
              </p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="bg-background py-16 lg:py-24">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-10">
        <div class="inline-flex items-center gap-3 mb-4">
          <div class="w-6 h-[2px] bg-primary"></div>
          <span class="text-xs font-bold uppercase tracking-[0.2em] text-primary">
            Interaktivt
          </span>
          <div class="w-6 h-[2px] bg-primary"></div>
        </div>
        <h2 class="font-heading text-3xl lg:text-4xl font-bold text-foreground tracking-tight mb-4">
          Räkna ut din krympplastning
        </h2>
        <p class="text-muted-foreground text-[15px] leading-relaxed max-w-2xl mx-auto">
          Skjut reglaget till din båts längd så får du en uppskattning. Boka
          tid via formuläret så bekräftar vi ett fast pris efter mätning.
        </p>
      </div>

      <ShrinkWrapCalculator client:visible />
    </div>
  </section>

  <section class="bg-muted/40 py-16 lg:py-24 border-t border-border">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="font-heading text-2xl lg:text-3xl font-bold text-foreground mb-8">
        Så här jobbar vi med priser
      </h2>
      <div class="space-y-5 text-muted-foreground leading-relaxed">
        <p>
          <span class="text-foreground font-semibold">Kostnadsbesked innan arbete.</span>
          Vi ger alltid ett pris eller ett tydligt intervall innan vi börjar.
          Skulle något oväntat dyka upp så stannar vi och stämmer av med dig.
        </p>
        <p>
          <span class="text-foreground font-semibold">Framkörningsavgift 685 kr.</span>
          En fast framkörningsavgift på 685 kr tillkommer per besök, oavsett
          var båten står. Inga dolda tillägg utöver det.
        </p>
        <p>
          <span class="text-foreground font-semibold">Garanti ingår.</span>
          Garanti på arbete och reservdelar enligt svensk konsumentlagstiftning. Du får
          dokumentation på vad som utförts.
        </p>
        <p>
          <span class="text-foreground font-semibold">F-skatt och faktura.</span>
          Vi är godkända för F-skatt. Faktura med vanliga betalningsvillkor.
          Swish och faktura vid mindre uppdrag.
        </p>
      </div>
    </div>
  </section>

  <CtaSection client:visible />
</BaseLayout>
