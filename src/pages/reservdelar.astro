---
import CtaSection from "@/components/sections/CtaSection.tsx";
import BaseLayout from "@/layouts/BaseLayout.astro";

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Hem", item: "https://batverkstad.se/" },
    { "@type": "ListItem", position: 2, name: "Reservdelar", item: "https://batverkstad.se/reservdelar/" },
  ],
};

const brands = [
  { name: "Yamaha", note: "Utombordare" },
  { name: "Mercury", note: "Utombordare" },
  { name: "Suzuki", note: "Utombordare" },
  { name: "Honda", note: "Utombordare" },
  { name: "Evinrude", note: "Utombordare" },
  { name: "Tohatsu", note: "Utombordare" },
  { name: "Kvalitetsfärg", note: "Bottenfärg och primer" },
];

const categories = [
  "Impellrar och vattenpumpkit",
  "Tändstift och tändspolar",
  "Olje- och bränslefilter",
  "Anoder för aluminium- och magnesiumskydd",
  "Propellrar och nav",
  "Bottenfärg, primer och slipmaterial",
  "Slangar, klämmor och kopplingar",
  "Batterier och laddare",
];
---

<BaseLayout
  title="Reservdelar utombordare | Priox Båtverkstad"
  description="Reservdelar till utombordare. Yamaha, Mercury, Suzuki, Honda, Evinrude, Tohatsu och fler. Vi sourcar både original och kvalitetsalternativ."
  schema={breadcrumbSchema}
>
  <section class="bg-background pt-20 pb-16 lg:pt-24 lg:pb-20 relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none opacity-50">
      <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-primary/10 rounded-full blur-[120px]"></div>
    </div>

    <div class="max-w-(--max-w-content) mx-auto px-6 relative z-10">
      <nav aria-label="Brödsmulor" class="mb-8 text-sm text-muted-foreground">
        <a href="/" class="hover:text-foreground transition-colors">Hem</a>
        <span class="mx-2 opacity-50">/</span>
        <span class="text-foreground">Reservdelar</span>
      </nav>

      <div class="max-w-3xl">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-6 h-[2px] bg-primary"></div>
          <span class="text-xs font-bold uppercase tracking-[0.2em] text-primary">
            Reservdelar och tillbehör
          </span>
        </div>
        <h1 class="font-heading text-4xl lg:text-5xl font-bold text-foreground tracking-tight leading-[1.05] mb-6">
          Reservdelar till
          <span class="block text-transparent bg-clip-text bg-gradient-to-r from-primary to-accent-sand">
            din båtmotor.
          </span>
        </h1>
        <p class="text-muted-foreground text-lg leading-relaxed">
          Vi sourcar reservdelar till samtliga större utombordarmärken.
          Original eller kvalitetsalternativ, du väljer. Behöver du en del
          beställd inför nästa servicebesök så ordnar vi det.
        </p>
      </div>
    </div>
  </section>

  <section class="bg-muted/40 py-16 lg:py-24 border-y border-border">
    <div class="max-w-(--max-w-content) mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16">
        <div>
          <h2 class="font-heading text-2xl lg:text-3xl font-bold text-foreground mb-6">
            Märken vi jobbar med
          </h2>
          <div class="grid grid-cols-2 gap-3">
            {
              brands.map((b) => (
                <div class="bg-card border border-border rounded-xl p-4 hover:border-primary/40 transition-colors">
                  <p class="font-heading text-base font-bold text-foreground">
                    {b.name}
                  </p>
                  <p class="text-xs text-muted-foreground mt-1">{b.note}</p>
                </div>
              ))
            }
          </div>
          <p class="text-sm text-muted-foreground mt-6 leading-relaxed">
            Med flera. Saknar ditt märke? Hör av dig så kollar vi om vi kan
            hjälpa till. Vi har breda kontakter i branschen.
          </p>
        </div>

        <div>
          <h2 class="font-heading text-2xl lg:text-3xl font-bold text-foreground mb-6">
            Vanliga reservdelar
          </h2>
          <ul class="space-y-3">
            {
              categories.map((c) => (
                <li class="flex items-start gap-3 text-[15px] text-foreground bg-card border border-border rounded-xl px-5 py-3">
                  <span class="w-1.5 h-1.5 rounded-full bg-primary mt-2.5 flex-shrink-0" />
                  <span class="leading-snug">{c}</span>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-background py-16 lg:py-24">
    <div class="max-w-2xl mx-auto px-6">
      <div class="bg-card border border-border rounded-3xl p-8 lg:p-12 text-center shadow-[0_20px_60px_-15px_rgba(0,0,0,0.4)]">
        <h2 class="font-heading text-2xl lg:text-3xl font-bold text-foreground mb-4">
          Behöver du en specifik del?
        </h2>
        <p class="text-muted-foreground leading-relaxed mb-8">
          Skicka en kort förfrågan med motormodell och vad det är du behöver.
          Vi återkommer med pris och leveranstid.
        </p>
        <div class="flex flex-col sm:flex-row justify-center gap-3">
          <a
            href="/kontakt/"
            class="inline-flex items-center justify-center gap-2 px-6 py-3.5 bg-primary text-primary-foreground font-bold rounded-xl hover:bg-primary/90 transition-all"
          >
            Skicka förfrågan
          </a>
          <a
            href="tel:+46767166716"
            class="inline-flex items-center justify-center gap-2 px-6 py-3.5 border border-border bg-background text-foreground font-medium rounded-xl hover:border-primary/40 transition-all"
          >
            Ring 0767-16 67 16
          </a>
        </div>
      </div>
    </div>
  </section>

  <CtaSection client:visible />
</BaseLayout>
