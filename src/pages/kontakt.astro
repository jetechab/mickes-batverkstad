---
import CtaSection from "@/components/sections/CtaSection.tsx";
import QuickBookSection from "@/components/sections/QuickBookSection.tsx";
import BaseLayout from "@/layouts/BaseLayout.astro";

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Hem", item: "https://batverkstad.se/" },
    { "@type": "ListItem", position: 2, name: "Kontakt", item: "https://batverkstad.se/kontakt/" },
  ],
};
---

<BaseLayout
  title="Kontakt | Mickes Båtverkstad"
  description="Kontakta Mickes Båtverkstad. Telefon 0767-16 67 16, mail mickes@batverkstad.se. Bas i Grebbestad."
  schema={breadcrumbSchema}
>
  <section class="bg-background pt-24 pb-20 lg:pt-28 lg:pb-28 relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none opacity-50">
      <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-primary/10 rounded-full blur-[120px]"></div>
      <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-accent-sand/10 rounded-full blur-[120px]"></div>
    </div>

    <div class="max-w-(--max-w-content) mx-auto px-6 relative z-10">
      <nav aria-label="Brödsmulor" class="mb-8 text-sm text-muted-foreground">
        <a href="/" class="hover:text-foreground transition-colors">Hem</a>
        <span class="mx-2 opacity-50">/</span>
        <span class="text-foreground">Kontakt</span>
      </nav>

      <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-start lg:items-stretch">
        <div>
          <div class="flex items-center gap-3 mb-6">
            <div class="w-6 h-[2px] bg-primary"></div>
            <span class="text-xs font-bold uppercase tracking-[0.2em] text-primary">
              Kontakt
            </span>
          </div>
          <h1
            class="font-heading text-4xl lg:text-5xl font-bold text-foreground mb-6 leading-[1.05] tracking-tight"
          >
            Hör av dig så
            <span class="block text-transparent bg-clip-text bg-gradient-to-r from-primary to-accent-sand">
              löser vi det.
            </span>
          </h1>
          <p class="text-muted-foreground text-lg leading-relaxed mb-10 max-w-(--max-w-text)">
            Ring eller maila. Vi återkommer inom 24 timmar.
          </p>

          <div class="space-y-4 mb-8">
            <a
              href="tel:+46767166716"
              class="flex items-center gap-4 p-5 rounded-2xl bg-card border border-border hover:border-primary/40 transition-all group"
            >
              <div class="w-12 h-12 rounded-xl bg-primary/10 border border-primary/30 flex items-center justify-center text-primary">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div>
                <p class="text-xs font-bold uppercase tracking-wider text-muted-foreground mb-1">
                  Telefon
                </p>
                <p class="font-heading text-xl font-bold text-foreground group-hover:text-primary transition-colors">
                  0767-16 67 16
                </p>
              </div>
            </a>

            <a
              href="mailto:mickes@batverkstad.se"
              class="flex items-center gap-4 p-5 rounded-2xl bg-card border border-border hover:border-primary/40 transition-all group"
            >
              <div class="w-12 h-12 rounded-xl bg-primary/10 border border-primary/30 flex items-center justify-center text-primary">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <p class="text-xs font-bold uppercase tracking-wider text-muted-foreground mb-1">
                  E-post
                </p>
                <p class="font-heading text-xl font-bold text-foreground group-hover:text-primary transition-colors">
                  mickes@batverkstad.se
                </p>
              </div>
            </a>
          </div>

          <div class="bg-card border border-border rounded-2xl p-5 lg:p-6 mb-4">
            <p class="text-xs font-bold uppercase tracking-[0.15em] text-muted-foreground mb-3">
              Adress
            </p>
            <p class="text-foreground font-medium">Mickes Båtverkstad AB</p>
            <p class="text-muted-foreground text-sm">Box 6, 457 02 Grebbestad</p>
          </div>

          <div class="bg-card border border-border rounded-2xl p-5 lg:p-6">
            <p class="text-xs font-bold uppercase tracking-[0.15em] text-muted-foreground mb-3">
              Öppettider
            </p>
            <p class="text-muted-foreground text-sm">Mån-Fre 08:00-17:00</p>
            <p class="text-muted-foreground text-sm">Helger: bokade jobb</p>
          </div>
        </div>

        <div class="flex flex-col gap-4 lg:h-full">
          <div class="bg-card border border-border rounded-2xl p-6 lg:p-8">
            <h2 class="font-heading text-xl font-bold text-foreground mb-2">
              Vill du skicka mer info?
            </h2>
            <p class="text-muted-foreground text-sm leading-relaxed mb-6">
              Använd vårt bokningsformulär om du har detaljer om båt, motor
              och önskat datum redan klart.
            </p>
            <a
              href="/boka/"
              class="inline-flex items-center justify-center gap-2 w-full px-6 py-4 bg-primary text-primary-foreground font-bold rounded-xl hover:bg-primary/90 transition-all duration-300 shadow-[0_0_25px_rgba(30,74,107,0.1)]"
            >
              Gå till bokningsformulär
            </a>
          </div>

          <div class="bg-card border border-border rounded-2xl p-6 lg:p-8 lg:flex-1 flex flex-col">
            <h2 class="font-heading text-xl font-bold text-foreground mb-2">
              Följ oss på Facebook
            </h2>
            <p class="text-muted-foreground text-sm leading-relaxed mb-6">
              Bilder från jobben och löpande uppdateringar.
            </p>
            <div class="lg:flex-1"></div>
            <a
              href="https://www.facebook.com/profile.php?id=100089773764804"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-2 w-full px-6 py-4 border border-border bg-background text-foreground font-bold rounded-xl hover:border-primary/40 transition-all"
            >
              Öppna Facebook
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <QuickBookSection client:visible />
  <CtaSection client:visible />
</BaseLayout>
