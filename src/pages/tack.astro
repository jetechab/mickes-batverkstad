---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="Tack för din förfrågan | Mickes Båtverkstad"
  description="Vi har tagit emot din förfrågan."
  noindex={true}
  hideStickyCta={true}
>
  <section class="bg-background min-h-[60vh] flex items-center py-20 lg:py-32 relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none opacity-50">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[600px] bg-primary/10 rounded-full blur-[120px]"></div>
    </div>

    <div class="max-w-2xl mx-auto px-6 text-center relative z-10">
      <div class="w-16 h-16 mx-auto mb-6 rounded-full bg-primary/10 border border-primary/40 flex items-center justify-center">
        <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
      </div>
      <h1 class="font-heading text-4xl lg:text-5xl font-bold text-foreground mb-6 leading-[1.1] tracking-tight">
        Tack, vi hör av oss
      </h1>
      <p class="text-muted-foreground text-lg leading-relaxed mb-10">
        Vi har tagit emot din förfrågan och återkommer inom 24 timmar.
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a
          href="/"
          class="inline-flex items-center justify-center gap-2 px-6 py-3.5 bg-primary text-primary-foreground font-bold rounded-xl hover:bg-primary/90 transition-all"
        >
          Tillbaka till startsidan
        </a>
        <a
          href="tel:+46767166716"
          class="inline-flex items-center justify-center gap-2 px-6 py-3.5 border border-border bg-card text-foreground font-medium rounded-xl hover:border-primary/40 transition-all"
        >
          Ring 0767-16 67 16
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
