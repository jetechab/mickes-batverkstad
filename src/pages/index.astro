---
import BrandsStrip from "@/components/sections/BrandsStrip.tsx";
import CtaSection from "@/components/sections/CtaSection.tsx";
import FAQSection, { faqs } from "@/components/sections/FAQSection.tsx";
import GalleryTeaser from "@/components/sections/GalleryTeaser.tsx";
import GeographySection from "@/components/sections/GeographySection.tsx";
import HeroSection from "@/components/sections/HeroSection.tsx";
import HowItWorksSection from "@/components/sections/HowItWorksSection.tsx";
import MeetMickeSection from "@/components/sections/MeetMickeSection.tsx";
import QuickBookSection from "@/components/sections/QuickBookSection.tsx";
import ReviewsSection from "@/components/sections/ReviewsSection.tsx";
import ServicesSection from "@/components/sections/ServicesSection.tsx";
import UspSection from "@/components/sections/UspSection.tsx";
import BaseLayout from "@/layouts/BaseLayout.astro";

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.plain },
  })),
};
---

<BaseLayout
  title="Mickes Båtverkstad – mobil båtservice i Bohuslän"
  description="Mobil båtverkstad i Bohuslän. Vi servar utombordare, krympplastar och bottenmålar på plats hos dig. Bas i Grebbestad. Bokning på 0767-16 67 16."
  schema={faqSchema}
>
  <HeroSection client:load />
  <UspSection client:visible />
  <ServicesSection client:visible />
  <MeetMickeSection client:visible />
  <GalleryTeaser client:visible />
  <HowItWorksSection client:visible />
  <BrandsStrip client:visible />
  <GeographySection client:visible />
  <ReviewsSection client:visible />
  <FAQSection client:visible />
  <QuickBookSection client:visible />
  <CtaSection client:visible />
</BaseLayout>
