---
import CtaSection from "@/components/sections/CtaSection.tsx";
import ServicesSection from "@/components/sections/ServicesSection.tsx";
import UspSection from "@/components/sections/UspSection.tsx";
import BaseLayout from "@/layouts/BaseLayout.astro";

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Hem", item: "https://batverkstad.se/" },
    {
      "@type": "ListItem",
      position: 2,
      name: "Tjänster",
      item: "https://batverkstad.se/tjanster/",
    },
  ],
};
---

<BaseLayout
  title="Tjänster | Mickes Båtverkstad"
  description="Utombordsservice, krympplastning och bottenmålning. Mobil båtverkstad som kommer ut till båten i Bohuslän, Dalsland och Värmland."
  schema={breadcrumbSchema}
>
  <section class="bg-background pt-32 pb-12 lg:pt-40 lg:pb-16 relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none opacity-50">
      <div class="absolute top-0 left-0 w-[500px] h-[500px] bg-primary/10 rounded-full blur-[120px]"></div>
      <div class="absolute bottom-0 right-0 w-[400px] h-[400px] bg-accent-sand/10 rounded-full blur-[120px]"></div>
    </div>

    <div class="max-w-(--max-w-content) mx-auto px-6 relative z-10">
      <nav aria-label="Brödsmulor" class="mb-8 text-sm text-muted-foreground">
        <a href="/" class="hover:text-foreground transition-colors">Hem</a>
        <span class="mx-2 opacity-50">/</span>
        <span class="text-foreground">Tjänster</span>
      </nav>

      <div class="flex items-center gap-3 mb-6">
        <div class="w-8 h-[2px] bg-primary"></div>
        <span class="text-xs font-bold uppercase tracking-[0.2em] text-primary">
          Översikt
        </span>
      </div>
      <h1
        class="font-heading text-4xl lg:text-6xl font-bold text-foreground tracking-tight leading-[1.05] mb-6 max-w-3xl"
      >
        Tre tjänster.
        <span
          class="block text-transparent bg-clip-text bg-gradient-to-r from-primary to-accent-sand"
          >En mobil verkstad.</span
        >
      </h1>
      <p class="text-muted-foreground text-lg leading-relaxed max-w-(--max-w-text)">
        Vi servar utombordare, vintertäcker med krympplast och bottenmålar.
        Allt görs där båten står, så slipper du transport och inomhusförvar.
      </p>
    </div>
  </section>

  <ServicesSection client:visible />
  <UspSection client:visible />
  <CtaSection client:visible />
</BaseLayout>
