---
import CtaSection from "@/components/sections/CtaSection.tsx";
import ServicePage from "@/components/ServicePage.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: "Bottenmålning",
  provider: {
    "@type": "LocalBusiness",
    name: "Priox Båtverkstad",
  },
  description:
    "Bottenmålning av båt med kvalitetsprodukter. Utförs på släp eller bockar hos kund. Bohuslän, Dalsland och Värmland.",
  serviceType: "Boat antifouling painting",
  areaServed: { "@type": "AdministrativeArea", name: "Bohuslän" },
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Hem", item: "https://batverkstad.se/" },
    { "@type": "ListItem", position: 2, name: "Tjänster", item: "https://batverkstad.se/tjanster/" },
    {
      "@type": "ListItem",
      position: 3,
      name: "Bottenmålning",
      item: "https://batverkstad.se/tjanster/bottenmalning/",
    },
  ],
};
---

<BaseLayout
  title="Bottenmålning båt | Kvalitetsfärg på plats"
  description="Bottenmålning med kvalitetsprodukter. Slip, primer och färg på släp eller bockar. Du slipper varv och transport. Bohuslän och Dalsland."
  schema={[serviceSchema, breadcrumbSchema]}
>
  <ServicePage
    eyebrow="Tjänst"
    title="Bottenmålning"
    titleAccent="med kvalitetsfärg, där båten står"
    lede="Vi utför bottenmålning på plats, direkt där båten står. Du slipper transport till varv och får ett noggrant utfört arbete med kvalitetsfärg för västkustens förhållanden."
    price="Från 2 500 kr"
    image="/img/bottenmalning.jpg"
    imageAlt="Bottenmålning av båtskrov med roller och vit bottenfärg"
    imageCaption="Bottenmålning gjord rätt syns på vattnet. Båten är snabbare, drar mindre och håller längre."
    bullets={[
      "Görs på släp, trailer eller bockar",
      "Kvalitetsfärg anpassad efter saltvatten",
      "Markerar vattenlinje",
      "Färg och förbrukningsmaterial ingår",
    ]}
    includesTitle="Det här gör vi"
    includes={[
      "Bedömning av befintligt skick",
      "Maskering av vattenlinje och detaljer",
      "Ett lager bottenfärg",
      "Färg och förbrukningsmaterial ingår",
      "Tipsar om sjösättning och underhåll",
    ]}
    sections={[
      {
        heading: "Vi använder kvalitetsleverantörer",
        body: "Vi använder kvalitetsleverantörer av bottenfärg. Färgerna är anpassade för olika vattentyper och båttyper. Vi väljer system baserat på var båten ska gå och hur snabbt du brukar köra.",
      },
      {
        heading: "Släp eller bockar, samma resultat",
        body: "Vi jobbar lika gärna på trailer, släp eller uppallad på bockar. Står båten redan färdig att börja målas så sparar du både tid och pengar genom att vi kommer ut istället för transport.",
      },
      {
        heading: "Hur ofta behövs det",
        body: "De flesta båtar i västkustvatten behöver bottenmålas varje eller varannan säsong, beroende på trafik och färgsystem. Vi gör en bedömning på plats och rekommenderar utifrån vad du har på skrovet idag.",
      },
      {
        heading: "Miljö och regler",
        body: "Vi följer gällande miljöregler för slip och färghantering. Våra produkter finns både som hård och självpolerande matt finish, samt biocidfria alternativ för områden där det krävs.",
      },
    ]}
  />

  <CtaSection client:visible />
</BaseLayout>
