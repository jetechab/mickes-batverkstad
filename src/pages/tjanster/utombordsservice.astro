---
import CtaSection from "@/components/sections/CtaSection.tsx";
import ServicePage from "@/components/ServicePage.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: "Utombordsservice",
  provider: {
    "@type": "LocalBusiness",
    name: "Mickes Båtverkstad AB",
  },
  description:
    "Planerad service och underhåll av utombordare på plats hos kund. Alla större märken. Bas i Grebbestad, hela Bohuslän, Dalsland och Värmland.",
  serviceType: "Outboard motor service",
  areaServed: { "@type": "AdministrativeArea", name: "Bohuslän" },
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Hem", item: "https://batverkstad.se/" },
    { "@type": "ListItem", position: 2, name: "Tjänster", item: "https://batverkstad.se/tjanster/" },
    {
      "@type": "ListItem",
      position: 3,
      name: "Utombordsservice",
      item: "https://batverkstad.se/tjanster/utombordsservice/",
    },
  ],
};
---

<BaseLayout
  title="Utombordsservice | Yamaha, Mercury, Suzuki och fler"
  description="Planerad service och underhåll av utombordare på plats hos dig. Yamaha, Mercury, Suzuki, Honda, Evinrude, Tohatsu med flera. Garanti på arbete och delar."
  schema={[serviceSchema, breadcrumbSchema]}
>
  <ServicePage
    eyebrow="Tjänst"
    title="Utombordsservice"
    titleAccent="service och underhåll, på plats"
    lede="Utbildad marin servicetekniker med lång erfarenhet på samtliga större märken. Vi gör planerad service och underhåll på din utombordare där båten står. Verkstadsbilen rullar fram, du slipper transport till varv."
    price="Från 2 195 kr"
    image="/img/service.jpg"
    imageAlt="Service av utombordsmotor med flushöra under spolning"
    imageCaption="Service och underhåll av utombordare, alla större märken. Garanti på arbete och delar."
    bullets={[
      "Yamaha, Mercury, Suzuki, Honda, Evinrude, Tohatsu med flera",
      "Årsservice och löpande underhåll",
      "Garanti på arbete och reservdelar",
      "Originaldelar och kvalitetsalternativ",
    ]}
    includesTitle="Vad ingår i en årsservice"
    includes={[
      "Olje- och oljefilterbyte",
      "Byte av tändstift",
      "Kontroll och byte av impeller",
      "Kontroll av växelhusolja",
      "Kontroll av batteri och anoder",
      "Test under last och dokumentation",
    ]}
    sections={[
      {
        heading: "Service inför säsongen",
        body: "Inför säsongsstart går vi igenom motorn så du inte fastnar vid första turen. Servicen säkerställer att grundfunktioner som tändning, kylning och bränsletillförsel fungerar. Vi gör testkörning innan vi lämnar över.",
      },
      {
        heading: "Löpande underhåll",
        body: "Planerade serviceintervall håller motorn i form över tid. Vi kommer ut, gör översynen, byter slitdelar i tid och dokumenterar vad som är gjort. Du får en motor som mår bra hela säsongen.",
      },
      {
        heading: "Garanti och dokumentation",
        body: "Du får dokumentation på vad som utförts och vilka delar som bytts. Garanti på arbete och delar enligt branschpraxis. Skulle något inte fungera som det ska efter besöket, hör av dig så löser vi det.",
      },
      {
        heading: "Reservdelar och tillbehör",
        body: "Behöver du en specifik reservdel eller tillbehör? Vi har bra kanaler för utombordare av alla större märken. Hör av dig så ordnar vi det inför nästa besök.",
      },
    ]}
  />

  <CtaSection client:visible />
</BaseLayout>
